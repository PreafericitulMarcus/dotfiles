# from .bashrc
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias alert='notify-send --urgency=low -i "$([ $? = 0 ] && echo terminal || echo error)" "$(history|tail -n1|sed -e '\''s/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//'\'')"'


alias vim="nvim"
alias sl="ls"
alias psa="ps auxf"
alias rm="rm -I"
alias mkdir="mkdir -p"
alias grep="rg --color=auto"
alias df="df -h"
alias path='echo -e ${PATH//:/\\n}'
alias ports="ss -tulanp"


# Requires installing stuff
alias bat="batcat" 
alias ls="eza -h --color=always --icons=auto --group-directories-first"
alias fd="fdfind"

# This is for the dotfiles bare repository
alias dotfile="/usr/bin/git --git-dir=$HOME/.dotfiles/ --work-tree=$HOME"
